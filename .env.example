# SearXNG Search MCP — Environment Variables

# Required: URL of your SearXNG instance (comma-separated for multi-instance)
SEARXNG_URL=http://localhost:8080

# Optional: API key if your instance requires authentication
# SEARXNG_API_KEY=

# Optional: Cache time-to-live in milliseconds (default: 300000 = 5 minutes)
# CACHE_TTL_MS=300000

# Optional: HTTP request timeout in milliseconds (default: 15000 = 15 seconds)
# REQUEST_TIMEOUT_MS=15000

# Optional: Maximum number of cached entries (default: 500)
# MAX_CACHE_SIZE=500

# Optional: Maximum concurrent requests to SearXNG (default: 8)
# MAX_CONCURRENT=8

# Optional: Maximum results per search query (default: 50)
# MAX_RESULTS=50

# Optional: Maximum fetched page content size in characters (default: 50000)
# MAX_FETCH_SIZE=50000

# Optional: Maximum retry attempts on SearXNG failure (default: 2)
# MAX_RETRIES=2

# Optional: Base delay for exponential backoff in ms (default: 500)
# RETRY_BASE_DELAY_MS=500

# Optional: Maximum delay cap for retries in ms (default: 5000)
# RETRY_MAX_DELAY_MS=5000
